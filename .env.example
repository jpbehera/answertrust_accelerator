# AnswerTrust accelerator — environment template (POWER-USER / CI path).
#
# RECOMMENDED: most adopters should run the guided setup instead of editing this
# file by hand:
#
#   azd auth login && azd init     # or: azd env new <name>
#   ./scripts/init-env.sh          # ./scripts/init-env.ps1 on Windows
#   azd up
#
# This file is the manual alternative for power users and CI: copy it to `.env`,
# fill in values, then load them into the azd environment. `.env` is gitignored;
# never commit real resource IDs or principal object IDs (and no secrets — azd
# .env files are plaintext; use Key Vault / managed identity for secrets).
#
# These variables feed two paths:
#   1. azd / Bicep control plane  -> infra/main.parameters.json (${VAR} bindings)
#   2. Fabric data-plane deploy   -> scripts/deploy-fabric-pipeline.sh (reads FABRIC_WORKSPACE_ID)
#
# Loading into azd (azd does NOT auto-read this file):
#   set -a; source .env; set +a
#   for v in AZURE_LOCATION FABRIC_WORKSPACE_ID FOUNDRY_PROJECT_ID FOUNDRY_ACCOUNT_NAME \
#            PURVIEW_ACCOUNT_NAME FABRIC_PRINCIPAL_ID FOUNDRY_PRINCIPAL_ID \
#            AT_ADMIN_PRINCIPAL_ID AT_ADMIN_PRINCIPAL_TYPE AT_NAME_PREFIX; do
#     [ -n "${!v}" ] && azd env set "$v" "${!v}"
#   done

# --- Azure context -----------------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_LOCATION=westus3

# --- Existing Fabric workspace (AnswerTrust is an add-on, not greenfield) -----
# Target Fabric workspace GUID that hosts the Lakehouse/Warehouse/Eventhouse.
FABRIC_WORKSPACE_ID=

# --- Existing Azure AI Foundry project ---------------------------------------
# Full resource id of the Foundry project (…/accounts/<acct>/projects/<project>).
FOUNDRY_PROJECT_ID=
# Foundry (Cognitive Services / AIServices) account name — used by foundry-connection.bicep.
FOUNDRY_ACCOUNT_NAME=

# --- Microsoft Purview --------------------------------------------------------
# Leave BLANK when using the unified tenant-level Purview portal (no ARM account).
PURVIEW_ACCOUNT_NAME=

# --- RBAC principals (object IDs) --------------------------------------------
# Optional service-principal/managed-identity object IDs; leave blank for single-user demo.
FABRIC_PRINCIPAL_ID=
FOUNDRY_PRINCIPAL_ID=
# Admin who receives AnswerTrust roles (required for rbac.bicep assignments).
AT_ADMIN_PRINCIPAL_ID=
# User | Group | ServicePrincipal
AT_ADMIN_PRINCIPAL_TYPE=User

# --- Naming ------------------------------------------------------------------
# Prefix for provisioned control-plane resources (App Insights, Log Analytics, …).
AT_NAME_PREFIX=answertrust
