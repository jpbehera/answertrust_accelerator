  "parameters": [],
  "baseQueries": [],
  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| where timestamp > ago(1d)\n| summarize AvgAnswerTrust = round(avg(answertrust_score), 3)",
      "id": "f7a1ba33-48d9-4e4d-bea3-37c4b4e1eb0a",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| where timestamp > ago(1d)\n| summarize TrustworthyPct = round(countif(trustworthy) * 100.0 / count(), 1)",
      "id": "a0e878ec-c612-44c9-9982-0338c265409a",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| summarize AvgScore = round(avg(answertrust_score), 3) by agent_id\n| order by AvgScore asc",
      "id": "6291b7ed-9edd-4cf7-94bd-210721a13a55",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| summarize AvgScore = round(avg(answertrust_score), 3) by bin(timestamp, 1h)\n| order by timestamp asc",
      "id": "bb87d65a-fb41-4ec3-971a-e83d64b76404",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| summarize AvgDQ = round(avg(dq_score), 3) by bin(timestamp, 1h)\n| order by timestamp asc",
      "id": "9bba7daf-9a47-4e31-9baa-e8f0c99f4f9e",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| summarize Answers = count() by dlp_decision\n| order by Answers desc",
      "id": "5cb9bc3f-ee0d-49ca-b999-5d3f502c1dbd",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "dq_runs_failed_rows\n| where timestamp > ago(7d)\n| project timestamp, trace_id, table_name, rule, dimension, failed_value\n| order by timestamp desc\n| take 100",
      "id": "1ec4c6b3-74f8-43e1-972b-e7eb71aaa8fc",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| summarize TotalCostUSD = round(sum(cost_usd), 2) by bin(timestamp, 1d)\n| order by timestamp asc",
      "id": "a2f0f5c5-cae6-4280-82a2-f75546554747",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| summarize P95LatencyMs = percentile(latency_ms, 95) by bin(timestamp, 1h)\n| order by timestamp asc",
      "id": "675ad86f-8245-488d-babe-8f6e8f2c9f1b",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| summarize Tokens = sum(tokens_used), CostUSD = round(sum(cost_usd), 2) by agent_id\n| order by Tokens desc",
      "id": "0e3ec2bc-08a7-4225-8d33-29e289b6196b",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| where array_length(red_team_flags) > 0\n| project timestamp, user_upn, agent_id, prompt, red_team_flags\n| order by timestamp desc\n| take 100",
      "id": "21168a33-4614-46b7-9fc7-cb0fcdb97ffb",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| where dlp_decision == \"BLOCK\"\n| summarize Blocks = count() by bin(timestamp, 1h)\n| order by timestamp asc",
      "id": "2cd00123-16c9-4522-8c44-26dd20007009",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "f930d384-96d1-478e-a880-7c3a4ecc5e81"
      },
      "text": "AnswerLedger\n| summarize AvgRows = avg(row_count), MaxRows = max(row_count) by agent_id\n| extend OversharingRatio = round(MaxRows / AvgRows, 1)\n| order by OversharingRatio desc",
      "id": "442b9a32-e967-4a33-8c49-04aa5a03e3e1",
      "usedVariables": []
    }
  ],
