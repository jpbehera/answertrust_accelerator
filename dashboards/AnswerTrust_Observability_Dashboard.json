      "clusterUri": "https://<YOUR_EVENTHOUSE>.z<N>.kusto.fabric.microsoft.com",
      "database": "<YOUR_DATABASE_ID>",
      "name": "answer_ledger_db",
      "id": "f930d384-96d1-478e-a880-7c3a4ecc5e81",
      "workspace": "<YOUR_WORKSPACE_ID>"
    }
  ],
  "pages": [
    {
      "id": "c64fd252-91ef-4334-826b-8adabb9e4bfb",
      "name": "Trust Scorecard"
    },
    {
      "id": "431b745a-36ee-4ada-a6d7-2c8e2325b90f",
      "name": "DQ Health"
    },
    {
      "id": "cd34e7c8-bdc2-48d2-b792-2d335e969cb6",
